    "agent": {
      "mode": "agent",
      "llm": {
        "model": "gpt-4o",
        "temperature": 0.5,
        "max_tokens": 2048
      },
      "acl": {
        "extra_block": ["curl", "wget"]
      }
    },
    "admin": {
      "mode": "admin"
    }
  }
